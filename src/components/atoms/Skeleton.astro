---
/**
 * Loading placeholder atom: a pulsing bordered block that stands in for
 * content while it loads. Purely decorative (`aria-hidden`).
 */
interface Props {
  /** CSS width value (e.g. `'100%'`, `'4rem'`) */
  width?: string;
  /** CSS height value (e.g. `'1rem'`) */
  height?: string;
  /** Additional CSS classes */
  class?: string;
}

const { width = '100%', height = '1rem', class: className = '' } = Astro.props;
---

<div class={`animate-pulse rounded-xs border-2 border-seam bg-concrete-2 ${className}`} style={`width: ${width}; height: ${height};`} aria-hidden="true"></div>
