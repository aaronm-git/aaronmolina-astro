---
import SectionHeader from '@/components/molecules/SectionHeader.astro';

interface Step {
  /** Large outlined step number (e.g. "01") */
  number: string;
  /** Small badge-style tag shown in the corner of the step card */
  tag: string;
  /** Step title */
  title: string;
  /** Step description */
  description: string;
}

/**
 * "How it works" process section - dark themed, listing ordered steps as a
 * grid of cards with a large outlined number and a corner tag. Composes
 * SectionHeader.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title */
  title: string;
  /** Process steps rendered in order */
  steps: Step[];
  class?: string;
}

const { eyebrow, title, steps, class: className = '' } = Astro.props;
---

<section class={`section-py border-y-2 border-ink bg-ink text-concrete ${className}`}>
  <div class="container">
    <SectionHeader eyebrow={eyebrow} title={title} tone="dark" class="mb-10" />

    <ol class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {
        steps.map(step => (
          <li class="border-seam bg-asphalt relative rounded-md border-2 p-6">
            <span class="font-display text-5xl leading-none font-black text-transparent" style="-webkit-text-stroke: 2px var(--color-signal);">
              {step.number}
            </span>
            <span class="border-seam text-steel absolute top-6 right-6 rounded-xs border px-2 py-0.5 font-mono text-[10px] tracking-[0.14em] uppercase">{step.tag}</span>
            <h3 class="font-display mt-4 text-xl font-black uppercase">{step.title}</h3>
            <p class="text-steel mt-2 text-sm">{step.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
