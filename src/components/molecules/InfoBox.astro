---
type Variant = 'paper' | 'muted';

/**
 * Molecule for a bordered callout box with an optional heading, used to
 * group related info or checklist content within a section.
 */
interface Props {
  /** Optional heading rendered above the slotted content */
  title?: string;
  /** Visual style variant */
  variant?: Variant;
  /** Additional CSS classes */
  class?: string;
}

const { title, variant = 'paper', class: className = '' } = Astro.props;

const variantClasses: Record<Variant, string> = {
  paper: 'bg-paper border-ink shadow-hard-sm',
  muted: 'bg-concrete-2 border-ink',
};
---

<div class={`rounded-md border-2 p-6 ${variantClasses[variant]} ${className}`}>
  {title && <h3 class="font-display text-ink mb-4 text-lg font-black tracking-tight uppercase">{title}</h3>}
  <slot />
</div>
