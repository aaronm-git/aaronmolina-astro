---
/**
 * Hire Services - Main overview page
 * Showcases all hiring service offerings
 */
import MainLayout from '@/layouts/main-layout.astro';
import HeroSection from '@/components/organisms/sections/HeroSection.astro';
import ServicesSection from '@/components/organisms/sections/ServicesSection.astro';
import CTASection from '@/components/organisms/sections/CTASection.astro';
import TechShowcase from '@/components/organisms/TechShowcase.astro';
import TechShowcaseMobile from '@/components/organisms/TechShowcaseMobile.astro';
import hireData from '@/content/site/hire.json';

const serviceOfferings = [
  {
    icon: 'code',
    title: 'Jamstack & Full Stack Development',
    description: 'High-performance static, hybrid, and full stack applications with Astro, Next.js, TanStack Start, and modern frameworks',
    href: '/hire/jamstack',
  },
  {
    icon: 'react',
    title: 'React Developer',
    description: 'Expert React development with TypeScript, hooks, server components, and AI integrations',
    href: '/hire/react-developer',
  },
  {
    icon: 'nextjs',
    title: 'Next.js Developer',
    description: 'Full stack React with server components, API routes, headless CMS, and optimization',
    href: '/hire/nextjs-developer',
  },
  {
    icon: 'globe',
    title: 'Headless CMS',
    description: 'Sanity, Storyblok, Strapi, and custom CMS implementation and migration',
    href: '/hire/headless-cms',
  },
  {
    icon: 'bolt',
    title: 'AI-Powered Development',
    description: 'Full stack applications with AI built in. OpenAI integrations, Claude Code workflows, and MCP server configuration',
    href: '/contact',
  },
];

const techSlugs = Array.from(
  new Set(hireData.main.skills.categories.flatMap((c: { skills: string[] }) => c.skills))
);

const title = 'Hire a Full Stack Developer | Services & Expertise | Aaron Molina';
const description = 'Hire a senior full stack developer for Jamstack, React, Next.js, AI-powered applications, and Headless CMS projects. 14+ years experience, remote US / Miami.';
---

<MainLayout title={title} description={description}>
  <HeroSection
    variant="split"
    headline="Let's Build Something Great"
    subheadline="Full Stack, Jamstack & AI-Powered Development"
    description="I offer specialized services across web development, headless CMS, and AI-powered applications. Select a service below to learn more about how I can help with your project."
    primaryCta={{
      label: 'Get in Touch',
      href: '/contact',
      icon: 'arrowRight',
    }}
    class="mb-16"
  >
    <div slot="right">
      <TechShowcaseMobile techs={techSlugs} />
      <TechShowcase techs={techSlugs} />
    </div>
  </HeroSection>

  <ServicesSection
    title="My Services"
    subtitle="Pick the expertise that fits your project"
    services={serviceOfferings}
    variant="grid"
    columns={2}
    class="mb-16 bg-muted/30 rounded-2xl"
  />

  <CTASection
    title="Ready to Start Your Project?"
    description="Whether you need a new website, an AI-powered application, or help scaling your team, I am here to help."
    buttonLabel="Get in Touch"
    buttonHref="/contact"
    class=""
  />
</MainLayout>
