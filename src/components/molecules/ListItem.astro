---
import Icon from '@/components/atoms/Icon.astro';
import { getCategoryIcon } from '@/lib/icons';

type Tone = 'light' | 'dark';

/**
 * Molecule rendering a checklist-style `<li>` with a leading category icon
 * and slotted text. Meant to be used inside a `<ul>`/`<ol>`.
 */
interface Props {
  /** Category key resolved to an icon via `getCategoryIcon`; no icon renders if it can't be resolved */
  icon?: string;
  /** Size in the type scale */
  size?: 'sm' | 'base';
  /** Tone of the surface this item sits on, controls text color */
  tone?: Tone;
  /** Additional CSS classes */
  class?: string;
}

const { icon = 'check', size = 'base', tone = 'light', class: className = '' } = Astro.props as Props;

const IconComponent = getCategoryIcon(icon);
const textColor = tone === 'dark' ? 'text-steel' : 'text-graphite';
const textSize = size === 'sm' ? 'text-sm' : 'text-base';
---

<li class={`flex items-start gap-2.5 ${textColor} ${textSize} ${className}`}>
  {IconComponent && <Icon icon={IconComponent} size="sm" color="signal-deep" class="mt-0.5 flex-shrink-0" />}
  <span><slot /></span>
</li>
