---
import Badge from '@/components/atoms/Badge.astro';

interface ManifestEntry {
  /** Entry title (e.g. project or task name) */
  title: string;
  /** Secondary meta line shown under the title (e.g. category or date) */
  meta: string;
  /** Status used to pick the badge label/variant for this entry */
  stamp: 'done' | 'pending' | 'review';
}

/**
 * Decorative "build manifest" card - a rotated, ticket-style panel listing
 * selected work items with status badges and a striped progress bar.
 * Typically slotted into a hero section (e.g. HeroSection's "right" slot).
 */
interface Props {
  /** Manifest line items rendered in order, numbered from 01 */
  entries: ManifestEntry[];
  /** Label shown above the progress bar (e.g. "Progress") */
  progressLabel: string;
  /** Fraction text displayed next to the progress label (e.g. "3/5") */
  progressFraction: string;
  /** Fill percentage (0-100) applied to the progress bar width */
  progressPercent: number;
  class?: string;
}

const { entries, progressLabel, progressFraction, progressPercent, class: className = '' } = Astro.props;

const stampVariant: Record<ManifestEntry['stamp'], 'stamp-done' | 'stamp-pending' | 'stamp-review'> = {
  done: 'stamp-done',
  pending: 'stamp-pending',
  review: 'stamp-review',
};

const stampLabel: Record<ManifestEntry['stamp'], string> = {
  done: 'Shipped',
  pending: 'Planned',
  review: 'In Review',
};
---

<div class={`w-full max-w-[460px] -rotate-[0.6deg] overflow-hidden rounded-md border-2 border-ink bg-paper shadow-[8px_8px_0_var(--color-signal)] ${className}`}>
  <div class="bg-ink flex items-baseline justify-between gap-3 px-4 py-3">
    <span class="text-signal font-mono text-xs font-bold tracking-[0.16em] uppercase">Build Manifest</span>
    <span class="text-steel font-mono text-xs">Selected work</span>
  </div>

  <div>
    {
      entries.map((entry, index) => (
        <div class="border-concrete-2 last:border-ink grid grid-cols-[34px_1fr_auto] items-center gap-3 border-b px-4 py-3 last:border-b-2">
          <span class="text-graphite font-mono text-xs font-bold">{String(index + 1).padStart(2, '0')}</span>
          <div>
            <p class="text-ink text-sm font-bold">{entry.title}</p>
            <p class="text-graphite mt-0.5 font-mono text-[10.5px] tracking-[0.06em] uppercase">{entry.meta}</p>
          </div>
          <Badge label={stampLabel[entry.stamp]} variant={stampVariant[entry.stamp]} size="sm" />
        </div>
      ))
    }
  </div>

  <div class="bg-paper px-4 py-4">
    <div class="mb-2 flex items-baseline justify-between">
      <span class="text-ink font-mono text-xs font-bold tracking-[0.14em] uppercase">{progressLabel}</span>
      <span class="font-display text-ink text-xl font-black tabular-nums">{progressFraction}</span>
    </div>
    <div class="border-ink bg-concrete h-4 overflow-hidden rounded-xs border-2">
      <div
        class="border-ink h-full border-r-2"
        style={`width: ${progressPercent}%; background: repeating-linear-gradient(-45deg, var(--color-signal) 0 10px, oklch(78% 0.21 137) 10px 20px);`}
      >
      </div>
    </div>
  </div>
</div>
