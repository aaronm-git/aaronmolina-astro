---
import type { CollectionEntry } from 'astro:content';
import SectionHeader from '@/components/molecules/SectionHeader.astro';
import RoleCard from '@/components/organisms/cards/RoleCard.astro';
import Button from '@/components/atoms/Button.astro';

interface CTA {
  /** Link text */
  label: string;
  /** Link destination */
  href: string;
}

/**
 * Work experience section rendering a stacked list of role cards, with an
 * optional section header and a trailing link. Composes SectionHeader and
 * RoleCard.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title */
  title: string;
  /** Role entries to render, one card per role */
  roles: CollectionEntry<'roles'>[];
  /** Organization entries keyed by slug, used to resolve each role's org logo/name */
  organizations: Map<string, CollectionEntry<'organizations'>>;
  /** Whether each RoleCard shows its full summary/highlights or a condensed teaser */
  showAllDetails?: boolean;
  /** Optional link rendered below the list (e.g. "View full experience") */
  cta?: CTA;
  class?: string;
}

const { eyebrow, title, roles, organizations, showAllDetails = false, cta, class: className = '' } = Astro.props;
---

<section class={`section-py ${className}`}>
  <div class="container">
    <SectionHeader eyebrow={eyebrow} title={title} class="mb-10" />

    <div class="grid grid-cols-1 gap-6">
      {roles.map(role => <RoleCard role={role} organization={organizations.get(role.data.organization)} showAllDetails={showAllDetails} />)}
    </div>

    {
      cta && (
        <div class="mt-8 text-center">
          <Button href={cta.href} variant="ghost-ink" size="sm">
            {cta.label}
          </Button>
        </div>
      )
    }
  </div>
</section>
