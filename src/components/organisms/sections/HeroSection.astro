---
import Heading from '@/components/atoms/Heading.astro';
import Text from '@/components/atoms/Text.astro';
import Button from '@/components/atoms/Button.astro';
import Badge from '@/components/atoms/Badge.astro';
import StencilGrid from '@/components/organisms/decorative/StencilGrid.astro';

type Variant = 'split' | 'minimal';

interface CTA {
  /** Button label */
  label: string;
  /** Button destination */
  href: string;
}

/**
 * Page hero section with two layout modes: `split` is a dark, two-column
 * hero (GSAP-animated entrance via data-hero-animate attributes, StencilGrid
 * background, optional "right" slot for supporting content like
 * BuildManifestCard) used on the homepage; `minimal` is a simpler light
 * hero for interior pages. Composes Heading, Text, Button, Badge, and
 * StencilGrid.
 */
interface Props {
  /** Layout mode; defaults to 'minimal' */
  variant?: Variant;
  /** Small label shown above the headline */
  eyebrow?: string;
  /** Main headline text */
  headline: string;
  /** Short supporting line shown under the headline (split variant only) */
  subheadline?: string;
  /** Longer supporting copy below the headline/subheadline */
  description?: string;
  /** Trust badges rendered along the bottom (split variant only) */
  badges?: string[];
  /** Primary call-to-action button (split variant only) */
  primaryCta?: CTA;
  /** Secondary call-to-action button (split variant only) */
  secondaryCta?: CTA;
  class?: string;
}

const { variant = 'minimal', eyebrow, headline, subheadline, description, badges, primaryCta, secondaryCta, class: className = '' } = Astro.props;

const hasRightSlot = Astro.slots.has('right');
---

{
  variant === 'split' && (
    <section class={`bg-ink text-concrete relative overflow-hidden py-18 ${className}`}>
      <StencilGrid />
      <div class={`relative z-10 container grid items-center gap-12 ${hasRightSlot ? 'lg:grid-cols-[7fr_5fr]' : ''}`}>
        <div class={hasRightSlot ? '' : 'max-w-3xl'}>
          {eyebrow && (
            <span
              data-hero-animate
              data-hero-order="0"
              class="border-seam bg-asphalt text-signal mb-6 inline-block rounded-xs border px-3 py-1 font-mono text-xs font-bold tracking-[0.18em] uppercase"
            >
              {eyebrow}
            </span>
          )}

          <Heading level={1} size="hero" class="text-concrete" data-hero-animate data-hero-order="1">
            {headline}
          </Heading>

          {subheadline && (
            <p data-hero-animate data-hero-order="2" class="text-signal mt-4 font-mono text-sm font-bold tracking-[0.1em] uppercase md:text-base">
              {subheadline}
            </p>
          )}

          {description && (
            <Text size="lg" color="steel" class="mt-5 max-w-[54ch]" balance data-hero-animate data-hero-order="3">
              {description}
            </Text>
          )}

          {(primaryCta || secondaryCta) && (
            <div data-hero-animate data-hero-order="4" class="mt-8 flex flex-wrap gap-4">
              {primaryCta && (
                <Button href={primaryCta.href} variant="primary" size="lg">
                  {primaryCta.label}
                </Button>
              )}
              {secondaryCta && (
                <Button href={secondaryCta.href} variant="secondary" size="lg">
                  {secondaryCta.label}
                </Button>
              )}
            </div>
          )}

          {badges && badges.length > 0 && (
            <div class="border-seam mt-8 flex flex-wrap gap-2 border-t pt-4">
              {badges.map(badge => (
                <Badge label={badge} variant="outline" size="sm" class="border-seam text-concrete" />
              ))}
            </div>
          )}

          <slot />
        </div>

        {hasRightSlot && (
          <div class="justify-self-center lg:justify-self-end" data-hero-animate data-hero-order="5">
            <slot name="right" />
          </div>
        )}
      </div>
    </section>
  )
}

{
  variant === 'minimal' && (
    <section class={`section-py ${className}`}>
      <div class="container max-w-3xl">
        {eyebrow && <span class="text-signal-deep mb-3 block font-mono text-xs font-bold tracking-[0.18em] uppercase">{eyebrow}</span>}
        <Heading level={1} size="xl">
          {headline}
        </Heading>
        {description && (
          <Text size="lg" class="mt-4" balance>
            {description}
          </Text>
        )}
        <slot />
      </div>
    </section>
  )
}

<script>
  import { initHeroEntrance } from '@/lib/animations';
  document.addEventListener('DOMContentLoaded', () => {
    initHeroEntrance();
  });
</script>
