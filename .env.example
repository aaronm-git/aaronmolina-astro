# OpenAI API key for the portfolio chat function. Keep the real key only in
# Netlify environment variables or an ignored local .env file.
OPENAI_API_KEY=
# Hard cap on combined input and output tokens per UTC day. The chat function
# returns 503 once this is exceeded. Default 100000 if unset.
MAX_DAILY_TOKENS=100000

# Optional comma-separated IPv4/IPv6 addresses that bypass visitor rate limits.
# Localhost is always exempt during development. Configure this in Netlify for production.
CHAT_ADMIN_IPS=203.0.113.10

# Neon database URL for the portfolio chat function.
NEON_DATABASE_URL=