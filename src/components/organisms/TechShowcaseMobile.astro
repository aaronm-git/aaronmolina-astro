---
/**
 * TechShowcaseMobile - Static mobile tech stack sticker board.
 * Renders a lighter comic-inspired grid for small screens without GSAP.
 */
import { getAllTechIcons } from '@/lib/tech-icons';
import { cn } from '@/lib/cn';

interface Props {
  /** Array of technology slugs to display */
  techs: string[];
  /** Additional CSS classes */
  class?: string;
}

const { techs, class: className = '' } = Astro.props;

/** Top 8 techs most in-demand for hiring, shown on mobile */
const mobileFeatured = ['react', 'nextjs', 'astro', 'typescript', 'nodejs', 'tailwindcss', 'aws', 'docker', 'postgresql'];
const icons = getAllTechIcons(techs.filter((t) => mobileFeatured.includes(t)));
---

<div class={cn('mt-8 lg:hidden', className)} aria-label="Core tech stack">
  <div class="grid grid-cols-2 gap-x-2.5 gap-y-4 min-[420px]:grid-cols-3 min-[420px]:gap-x-3 min-[420px]:gap-y-5">
    {icons.map((icon, index) => {
      const rotationClass =
        index % 5 === 1 ? '-rotate-2' : index % 5 === 3 ? 'rotate-2' : '-rotate-1';
      const liftClass = index % 6 === 2 ? '-translate-y-1' : '';

      return (
        <div class={cn('flex flex-col items-center gap-1.5 px-0.5', rotationClass, liftClass)}>
          <div
            class="relative flex h-14 w-14 items-center justify-center rounded-[1.1rem] border-2 border-black bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(250,246,236,0.98))] shadow-[3px_3px_0_#111] min-[420px]:h-16 min-[420px]:w-16"
            style={`
              box-shadow:
                3px 3px 0 #111111,
                inset 0 0 0 2px color-mix(in srgb, ${icon.color} 22%, transparent);
            `}
          >
            <div
              class="absolute inset-[0.35rem] rounded-[0.9rem] border-[1.5px] min-[420px]:inset-[0.45rem]"
              style={`
                border-color: color-mix(in srgb, ${icon.color} 30%, transparent);
                background: color-mix(in srgb, ${icon.color} 10%, white);
              `}
            ></div>
            <img
              src={icon.src}
              alt=""
              aria-hidden="true"
              class="relative z-10 h-6 w-6 select-none min-[420px]:h-7 min-[420px]:w-7"
              loading="lazy"
              decoding="async"
              draggable="false"
            />
          </div>

          <div class="relative w-full max-w-[6.5rem]">
            <div class="flex min-h-[2.05rem] items-center justify-center rounded-full border-2 border-black bg-[linear-gradient(180deg,rgba(255,252,245,0.98),rgba(255,244,221,0.98))] px-2.5 py-1 text-center text-[0.63rem] font-black uppercase leading-[0.95] tracking-[0.04em] text-black shadow-[2px_2px_0_#111] min-[420px]:min-h-[2.2rem] min-[420px]:text-[0.68rem]">
              {icon.title}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>
