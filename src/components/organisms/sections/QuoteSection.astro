---
/**
 * Static pull-quote/testimonial section - a single fixed blockquote about
 * the author's AI-assisted workflow, styled as a large stamped card.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section class={`section-py ${className}`}>
  <div class="container">
    <figure class="border-ink bg-paper relative mx-auto max-w-[900px] rounded-md border-2 p-8 shadow-[8px_8px_0_var(--color-signal)] sm:p-10">
      <span class="font-display border-ink bg-signal shadow-hard-sm absolute -top-4 left-6 rounded-xs border-2 px-2 pt-1 text-2xl font-black"> &ldquo; </span>
      <blockquote>
        <p class="font-display text-ink text-[clamp(19px,2.4vw,27px)] leading-snug font-black">
          I stopped writing every line by hand. I pair with Claude Code and
          <span class="bg-signal px-1">Fable 5</span> on real production work end to end, and I still make every architecture call before a single file changes.
        </p>
      </blockquote>
      <figcaption class="border-concrete-2 mt-4 flex flex-wrap justify-between gap-3 border-t pt-3">
        <span class="text-ink text-sm font-bold">Aaron Molina</span>
        <span class="text-graphite font-mono text-xs tracking-[0.12em] uppercase">Full stack Jamstack developer</span>
      </figcaption>
    </figure>
  </div>
</section>
