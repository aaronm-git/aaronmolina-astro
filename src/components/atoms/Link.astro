---
import { FaArrowRight } from '@/lib/icons';

type LinkVariant = 'signal' | 'muted' | 'ink';

/**
 * Inline text link atom, styled as an underlined uppercase mono link.
 * Renders as an `<a>` with an optional trailing arrow icon.
 */
interface Props {
  /** Destination URL */
  href: string;
  /** Visual style variant */
  variant?: LinkVariant;
  /** Size in the type scale */
  size?: 'sm' | 'base';
  /** Renders a trailing arrow icon after the slotted label */
  showArrow?: boolean;
  /** Opens the link in a new tab with `rel="noopener noreferrer"` */
  external?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const { href, variant = 'signal', size = 'base', showArrow = false, external = false, class: className = '' } = Astro.props as Props;

const variantClasses: Record<LinkVariant, string> = {
  signal: 'text-signal-deep hover:text-ink',
  muted: 'text-graphite hover:text-ink',
  ink: 'text-ink hover:text-signal-deep',
};

const sizeClasses: Record<'sm' | 'base', string> = {
  sm: 'text-sm',
  base: 'text-base',
};
---

<a
  href={href}
  class={`inline-flex items-center gap-1.5 font-mono font-bold tracking-wide uppercase underline decoration-2 underline-offset-2 transition-colors ${variantClasses[variant]} ${sizeClasses[size]} ${className}`}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <slot />
  {showArrow && <FaArrowRight className="h-3 w-3" />}
</a>
