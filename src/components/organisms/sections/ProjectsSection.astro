---
import type { CollectionEntry } from 'astro:content';
import SectionHeader from '@/components/molecules/SectionHeader.astro';
import ProjectCard from '@/components/organisms/cards/ProjectCard.astro';
import Button from '@/components/atoms/Button.astro';

interface CTA {
  /** Link text */
  label: string;
  /** Link destination */
  href: string;
}

/**
 * Portfolio/projects section rendering a responsive grid of project cards,
 * with an optional section header and a trailing "view all" link. Composes
 * SectionHeader, ProjectCard, and Button.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title; when omitted, the header block is not rendered */
  title?: string;
  /** Project entries to render as cards */
  projects: CollectionEntry<'projects'>[];
  /** Number of grid columns at desktop width; defaults to 3 */
  columns?: 2 | 3;
  /** Whether to show each project's completion date */
  showCompletedDate?: boolean;
  /** Optional link rendered below the grid (e.g. "View all projects") */
  cta?: CTA;
  class?: string;
}

const { eyebrow, title, projects, columns = 3, showCompletedDate = false, cta, class: className = '' } = Astro.props;

const colClasses: Record<2 | 3, string> = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-2 lg:grid-cols-3',
};
---

<section class={`section-py ${className}`}>
  <div class="container">
    {title && <SectionHeader eyebrow={eyebrow} title={title} class="mb-10" />}

    <div class={`grid grid-cols-1 gap-6 ${colClasses[columns]}`}>
      {projects.map(project => <ProjectCard project={project} showCompletedDate={showCompletedDate} />)}
    </div>

    {
      cta && (
        <div class="mt-8 text-center">
          <Button href={cta.href} variant="ghost-ink" size="sm">
            {cta.label}
          </Button>
        </div>
      )
    }
  </div>
</section>
