---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@/utils/date-format';

/**
 * Molecule that surfaces related blog posts based on shared tags, ranked by
 * tag overlap then recency. Renders nothing if no related posts are found
 * or if publishDate is missing/in the future.
 */
interface Props {
  /** Slug of the post being viewed; excluded from the related list */
  currentSlug: string;
  /** Tags of the post being viewed, used to score candidate posts by overlap */
  currentTags: string[];
  /** Full pool of blog posts to consider as related-post candidates */
  posts: CollectionEntry<'blog'>[];
  /** Maximum number of related posts to render */
  maxPosts?: number;
  /** Additional CSS classes */
  class?: string;
}

const { currentSlug, currentTags = [], posts, maxPosts = 3, class: className = '' } = Astro.props;

const currentDate = new Date();
const relatedPosts = posts
  .filter(post => post.data.slug !== currentSlug)
  .filter(post => post.data.publishDate !== null)
  .filter(post => post.data.publishDate! <= currentDate)
  .map(post => {
    const postTags = post.data.tags || [];
    const sharedTags = postTags.filter(tag => currentTags.includes(tag));
    return { post, score: sharedTags.length };
  })
  .filter(item => item.score > 0)
  .sort((a, b) => (b.score !== a.score ? b.score - a.score : b.post.data.publishDate!.getTime() - a.post.data.publishDate!.getTime()))
  .slice(0, maxPosts)
  .map(item => item.post);

if (relatedPosts.length === 0) {
  return null;
}
---

<aside class={`border-t-2 border-seam pt-8 ${className}`}>
  <h2 class="font-display text-ink mb-6 text-xl font-black tracking-tight uppercase">Related Articles</h2>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      relatedPosts.map(post => (
        <a
          href={`/blog/${post.data.slug}`}
          class="group border-ink bg-paper shadow-hard-sm rounded-sm border-2 p-4 transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[5px_5px_0_var(--color-ink)]"
        >
          <h3 class="text-ink mb-2 line-clamp-2 font-bold">{post.data.title}</h3>
          {post.data.description && <p class="text-graphite mb-3 line-clamp-2 text-sm">{post.data.description}</p>}
          <time class="text-graphite font-mono text-xs uppercase">{formatDate(post.data.publishDate!, 'short')}</time>
        </a>
      ))
    }
  </div>
</aside>
