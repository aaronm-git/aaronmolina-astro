---
import type { CollectionEntry } from 'astro:content';
import MainLayout from '@/layouts/main-layout.astro';
import HeroSection from '@/components/organisms/sections/HeroSection.astro';
import StatsSection from '@/components/organisms/sections/StatsSection.astro';
import FeaturesSection from '@/components/organisms/sections/FeaturesSection.astro';
import SkillsSection from '@/components/organisms/sections/SkillsSection.astro';
import ProjectsSection from '@/components/organisms/sections/ProjectsSection.astro';
import FAQSection from '@/components/organisms/sections/FAQSection.astro';
import CTASection from '@/components/organisms/sections/CTASection.astro';
import HireNavigationTabs from '@/components/molecules/HireNavigationTabs.astro';
import type { TechMap } from '@/utils/tech-lookup';

/** Content for the split-variant hero at the top of a hire page */
interface HeroProps {
  headline: string;
  subheadline?: string;
  description?: string;
  badges?: string[];
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

/** A single figure shown in the stats strip (e.g. "10+ Years") */
interface StatItem {
  value: string;
  suffix?: string;
  label: string;
}

/** A service offering rendered as one bento card in the "How I can help" grid */
interface ServiceItem {
  title: string;
  description: string;
}

/** A single feature/benefit card in the two-column features grid */
interface FeatureItem {
  title: string;
  description: string;
}

/** A named group of skills rendered in the skills section */
interface SkillCategory {
  name: string;
  skills: string[];
}

/** A single question/answer pair in the FAQ accordion */
interface FAQItem {
  question: string;
  answer: string;
}

/** Content for the closing call-to-action section */
interface CTAProps {
  title: string;
  description?: string;
  buttonLabel: string;
  buttonHref: string;
}

/**
 * Shared template for all `/hire/*` landing pages — composes the hire-page
 * navigation tabs, hero, stats strip, services bento grid, a two-column
 * features grid, skills section, optional featured-projects section, FAQ
 * accordion, and closing CTA section.
 */
interface Props {
  /** Page `<title>` */
  title: string;
  /** Meta description */
  description?: string;
  /** Current route, used to highlight the active tab in `HireNavigationTabs` */
  currentPath: string;
  /** Hero section content */
  hero: HeroProps;
  /** Figures shown in the stats strip */
  stats: StatItem[];
  /** Services section heading, subheading, and bento card items */
  services: { title: string; subtitle?: string; items: ServiceItem[] };
  /** Phase label applied to each service bento card, matched by index */
  servicePhaseTags: string[];
  /** Features section heading and card items */
  features: { title: string; items: FeatureItem[] };
  /** Skills section heading, subheading, categories, and tag lookup */
  skills: { title: string; subtitle?: string; categories: SkillCategory[]; techMap: TechMap };
  /** Featured projects section heading, items, and "view all" link */
  projects: { title: string; items: CollectionEntry<'projects'>[]; viewAllHref: string; viewAllLabel: string };
  /** FAQ section heading and items */
  faq: { title: string; items: FAQItem[] };
  /** Closing CTA section content */
  cta: CTAProps;
}

const { title, description, currentPath, hero, stats, services, servicePhaseTags, features, skills, projects, faq, cta } = Astro.props as Props;

const bentoCards = services.items.map((item, i) => ({
  phase: servicePhaseTags[i] ?? 'Build',
  title: item.title,
  description: item.description,
  span: (i % 2 === 0 ? 5 : 7) as 5 | 7,
}));
---

<MainLayout title={title} description={description}>
  <HireNavigationTabs currentPath={currentPath} />

  <HeroSection
    variant="split"
    headline={hero.headline}
    subheadline={hero.subheadline}
    description={hero.description}
    badges={hero.badges}
    primaryCta={hero.primaryCta}
    secondaryCta={hero.secondaryCta}
  />

  <StatsSection stats={stats} tone="light" />

  <FeaturesSection eyebrow="How I can help" title={services.title} description={services.subtitle} cards={bentoCards} />

  <section class="section-py">
    <div class="container">
      <h2 class="font-display text-ink mb-8 text-2xl font-black tracking-tight uppercase md:text-3xl">{features.title}</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          features.items.map(item => (
            <div class="border-ink bg-paper shadow-hard-sm rounded-md border-2 p-6">
              <h3 class="text-ink mb-2 font-bold">{item.title}</h3>
              <p class="text-graphite text-sm">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <SkillsSection eyebrow="Tools" title={skills.title} description={skills.subtitle} categories={skills.categories} techMap={skills.techMap} />

  {projects.items.length > 0 && <ProjectsSection title={projects.title} projects={projects.items} cta={{ label: projects.viewAllLabel, href: projects.viewAllHref }} />}

  <FAQSection eyebrow="Before you reach out" title={faq.title} faqs={faq.items} />

  <CTASection title={cta.title} description={cta.description} buttonLabel={cta.buttonLabel} buttonHref={cta.buttonHref} />
</MainLayout>
