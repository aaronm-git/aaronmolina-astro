---
type DividerVariant = 'line' | 'tape';

/**
 * Horizontal rule atom for separating content sections.
 * `line` renders a plain `<hr>`; `tape` renders a decorative diagonal
 * hazard-stripe bar (`role="presentation"`, not a semantic separator).
 */
interface Props {
  /** Visual style variant */
  variant?: DividerVariant;
  /** Additional CSS classes */
  class?: string;
}

const { variant = 'line', class: className = '' } = Astro.props;
---

{variant === 'line' && <hr class={`border-seam border-t-2 ${className}`} />}

{
  variant === 'tape' && (
    <div
      role="presentation"
      class={`border-ink h-3.5 border-y-2 ${className}`}
      style="background: repeating-linear-gradient(-45deg, var(--color-signal) 0 14px, var(--color-ink) 14px 28px);"
    />
  )
}
