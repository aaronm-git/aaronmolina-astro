---
import SocialLink from './SocialLink.astro';

type Tone = 'light' | 'dark';

/** Data for a single social link rendered by the `SocialLink` atom */
interface SocialLinkData {
  platform: string;
  url: string;
  label?: string;
  ariaLabel?: string;
}

/**
 * Molecule rendering a row of `SocialLink` icons from a list of platform/url data.
 */
interface Props {
  /** Social links to render, in order */
  links: SocialLinkData[];
  /** Tone of the surface this row sits on, passed through to each icon */
  tone?: Tone;
  /** Additional CSS classes */
  class?: string;
}

const { links, tone = 'dark', class: className = '' } = Astro.props;
---

<div class={`flex items-center gap-1 ${className}`}>
  {links.map(link => <SocialLink platform={link.platform} url={link.url} label={link.label} ariaLabel={link.ariaLabel} tone={tone} />)}
</div>
