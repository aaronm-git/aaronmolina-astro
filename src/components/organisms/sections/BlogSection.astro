---
import type { CollectionEntry } from 'astro:content';
import SectionHeader from '@/components/molecules/SectionHeader.astro';
import BlogPostCard from '@/components/organisms/cards/BlogPostCard.astro';
import Button from '@/components/atoms/Button.astro';
import type { TechMap } from '@/utils/tech-lookup';

interface CTA {
  /** Link text */
  label: string;
  /** Link destination */
  href: string;
}

/**
 * Homepage/blog index section rendering a responsive grid of blog post
 * previews, with an optional section header and a trailing "view all" link.
 * Composes SectionHeader, BlogPostCard, and Button.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title; when omitted, the header block is not rendered */
  title?: string;
  /** Blog post entries to render as cards */
  posts: CollectionEntry<'blog'>[];
  /** Technology id-to-label lookup passed through to each card's tag list */
  techMap?: TechMap;
  /** Whether to show the tag list on each card */
  showTags?: boolean;
  /** Optional link rendered below the grid (e.g. "View all posts") */
  cta?: CTA;
  class?: string;
}

const { eyebrow, title, posts, techMap, showTags = false, cta, class: className = '' } = Astro.props;
---

<section class={`section-py ${className}`}>
  <div class="container">
    {title && <SectionHeader eyebrow={eyebrow} title={title} class="mb-10" />}

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map(post => <BlogPostCard post={post} techMap={techMap} showTags={showTags} />)}
    </div>

    {
      cta && (
        <div class="mt-8 text-center">
          <Button href={cta.href} variant="ghost-ink" size="sm">
            {cta.label}
          </Button>
        </div>
      )
    }
  </div>
</section>
