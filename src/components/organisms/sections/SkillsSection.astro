---
import SectionHeader from '@/components/molecules/SectionHeader.astro';
import Badge from '@/components/atoms/Badge.astro';
import type { TechMap } from '@/utils/tech-lookup';
import { getTechName } from '@/utils/tech-lookup';

interface Category {
  /** Category heading (e.g. "Frontend", "Backend") */
  name: string;
  /** Technology ids belonging to this category, resolved via techMap */
  skills: string[];
}

/**
 * Skills section rendering skill categories as a two-column grid of cards,
 * each showing its category name and a row of technology badges. Composes
 * SectionHeader and Badge.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title */
  title: string;
  /** Optional supporting copy below the title */
  description?: string;
  /** Skill categories to render */
  categories: Category[];
  /** Technology id-to-label lookup used to render human-readable skill badges */
  techMap: TechMap;
  class?: string;
}

const { eyebrow, title, description, categories, techMap, class: className = '' } = Astro.props;
---

<section class={`section-py ${className}`}>
  <div class="container">
    <SectionHeader eyebrow={eyebrow} title={title} description={description} class="mb-10" />

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        categories.map(category => (
          <div class="border-ink bg-paper shadow-hard-sm rounded-md border-2 p-5">
            <h3 class="text-signal-deep mb-3 font-mono text-xs font-bold tracking-[0.14em] uppercase">{category.name}</h3>
            <div class="flex flex-wrap gap-2">
              {category.skills.map(skill => (
                <Badge label={getTechName(skill, techMap)} variant="default" size="sm" />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
