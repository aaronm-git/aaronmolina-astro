---
import SectionHeader from '@/components/molecules/SectionHeader.astro';

interface FAQItem {
  /** Question text shown in the collapsed summary */
  question: string;
  /** Answer text revealed when the item is expanded */
  answer: string;
}

/**
 * FAQ accordion section built from native `<details>`/`<summary>` elements,
 * numbered from 01. Composes SectionHeader.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title */
  title: string;
  /** Question/answer pairs rendered as accordion items */
  faqs: FAQItem[];
  class?: string;
}

const { eyebrow, title, faqs, class: className = '' } = Astro.props;
---

<section class={`section-py ${className}`}>
  <div class="container mx-auto max-w-[900px]">
    <SectionHeader eyebrow={eyebrow} title={title} class="mb-8" />

    {
      faqs.map((faq, index) => (
        <details class="group border-ink bg-paper open:shadow-hard-sm mb-3 rounded-sm border-2">
          <summary class="text-ink flex cursor-pointer list-none items-baseline gap-3 p-4 font-bold marker:content-none">
            <span class="text-signal-deep flex-none font-mono text-xs font-bold">{String(index + 1).padStart(2, '0')}</span>
            <span class="flex-1">{faq.question}</span>
            <span class="flex-none font-mono text-lg transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="text-graphite max-w-[68ch] px-4 pb-4 pl-11 text-sm">{faq.answer}</p>
        </details>
      ))
    }
  </div>
</section>
