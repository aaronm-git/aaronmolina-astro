---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Badge from '@/components/atoms/Badge.astro';

interface Company {
  /** Company name */
  name: string;
  /** Alt text for the company's logo image */
  alt: string;
  /** Logo image asset */
  logo: ImageMetadata;
}

/**
 * Trust strip banner shown near the top of a page - a guarantee statement
 * with badges, followed by a grid of client/company logos.
 */
interface Props {
  /** Guarantee statement shown next to the checkmark icon */
  guaranteeText: string;
  /** Small badge labels rendered next to the guarantee text */
  badges: string[];
  /** Company logos to render in the grid below */
  companies: Company[];
  class?: string;
}

const { guaranteeText, badges, companies, class: className = '' } = Astro.props;
---

<section class={`border-b-2 border-ink bg-concrete-2 py-6 ${className}`}>
  <div class="container flex flex-wrap items-center justify-between gap-4">
    <p class="text-ink flex max-w-[46ch] items-center gap-3 text-sm font-bold">
      <span class="border-ink bg-signal shadow-hard-sm flex h-10 w-10 flex-none items-center justify-center rounded-full border-2 font-mono text-sm font-bold"> &check; </span>
      <span>{guaranteeText}</span>
    </p>
    <div class="flex flex-wrap gap-2">
      {badges.map(badge => <Badge label={badge} variant="default" size="sm" />)}
    </div>
  </div>

  <div class="container mt-6 grid grid-cols-2 items-center gap-4 md:grid-cols-4">
    {
      companies.map(company => (
        <div class="border-ink bg-paper flex items-center justify-center rounded-sm border-2 p-4">
          <Image src={company.logo} alt={company.alt} width={160} height={64} class="max-h-8 w-auto object-contain" loading="lazy" />
        </div>
      ))
    }
  </div>
</section>
