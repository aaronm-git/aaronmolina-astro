# Anthropic API key for the portfolio chat function (Claude Haiku 4.5)
ANTHROPIC_API_KEY=

# Hard cap on combined input+output tokens per UTC day. The chat function
# returns 503 once this is exceeded. Default 500_000 if unset.
MAX_DAILY_TOKENS=500000

# Email address that receives lead notifications from /api/lead.
LEAD_NOTIFY_EMAIL=aaron@pagelyft.studio

# Resend transactional email (optional). When unset, leads are still
# persisted to Netlify Blobs but no email is sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=leads@aaronmolina.me
