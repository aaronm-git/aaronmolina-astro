---
import SectionHeader from '@/components/molecules/SectionHeader.astro';

interface Row {
  /** Row label describing what is being compared (leftmost cell) */
  criterion: string;
  /** One value per column, in the same order as Props.columns */
  values: string[];
  /** Optional footnote for this row */
  note?: string;
}

/**
 * "Why work with me" style comparison table - dark section comparing the
 * author against alternatives (e.g. agency, freelancer) across a set of
 * criteria. Composes SectionHeader.
 */
interface Props {
  /** Small label shown above the title */
  eyebrow?: string;
  /** Section title */
  title: string;
  /** Optional supporting copy below the title */
  description?: string;
  /** Column headers; the first column is treated as the highlighted option */
  columns: string[];
  /** Table rows, one per comparison criterion */
  rows: Row[];
  class?: string;
}

const { eyebrow, title, description, columns, rows, class: className = '' } = Astro.props;
---

<section class={`section-py bg-ink text-concrete ${className}`}>
  <div class="container">
    <SectionHeader eyebrow={eyebrow} title={title} description={description} tone="dark" class="mb-10" />

    <div class="overflow-x-auto">
      <table class="border-seam bg-asphalt w-full min-w-[640px] border-collapse border-2">
        <thead>
          <tr>
            <th class="border-seam text-steel border p-4 text-left font-mono text-xs tracking-[0.14em] uppercase">What to compare</th>
            {
              columns.map((col, i) => (
                <th class={`border-seam border p-4 text-left font-mono text-xs tracking-[0.14em] uppercase ${i === 0 ? 'bg-signal text-ink' : 'text-steel'}`}>{col}</th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map(row => (
              <tr>
                <td class="border-seam border p-4 text-sm font-bold">{row.criterion}</td>
                {row.values.map((value, i) => (
                  <td class={`border-seam border p-4 font-mono text-xs tracking-[0.08em] uppercase ${i === 0 ? 'text-signal font-bold' : 'text-steel'}`}>{value}</td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
