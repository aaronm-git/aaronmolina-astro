---
import '@/styles/global.css';
import Header from '@/components/organisms/navigation/Header.astro';
import Footer from '@/components/organisms/navigation/Footer.astro';
import Breadcrumbs from '@/components/molecules/Breadcrumbs.astro';
import { generateBreadcrumbs } from '@/utils/breadcrumbs';
import settings from '@/content/site/settings.json';

import favicon from '@/favicon_io/android-chrome-512x512.png';

/**
 * Base HTML layout used by every page — sets up `<head>` meta tags (Open
 * Graph, Twitter Card, JSON-LD Person schema, Umami analytics), and renders
 * the Header, path-based breadcrumbs, the page content via `<slot />`, and
 * the Footer. Also wires up the GSAP scroll-reveal animations once the DOM
 * is ready.
 */
export interface Props {
  /** Page `<title>`, and OG/Twitter title; falls back to the site title */
  title?: string;
  /** Meta description, and OG/Twitter description; falls back to the site description */
  description?: string;
}

const { title = settings.siteTitle, description = settings.siteDescription } = Astro.props;

// Generate breadcrumbs from current pathname
const breadcrumbs = generateBreadcrumbs(Astro.url.pathname);
---

<html lang="en" class="js">
  <head>
    <!-- Meta Tags -->
    <!-- General -->
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {settings.keywords?.length ? <meta name="keywords" content={settings.keywords.join(', ')} /> : null}

    <!-- Umami Analytics -->
    {
      settings.analytics?.umamiScriptSrc && settings.analytics?.umamiWebsiteId ? (
        <script is:inline defer src={settings.analytics.umamiScriptSrc} data-website-id={settings.analytics.umamiWebsiteId} />
      ) : null
    }

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- <meta property="og:image" content={siteConfig.image} /> -->
    <meta property="og:url" content={settings.siteUrl} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <!-- <meta property="twitter:image" content={siteConfig.image} /> -->

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: settings.author.name,
        url: settings.siteUrl,
        email: settings.author.email,
        jobTitle: settings.author.jobTitle,
        description: settings.author.bio,
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Miami',
          addressRegion: 'FL',
          addressCountry: 'US',
        },
        sameAs: settings.author.socialLinks?.map((link: { url: string }) => link.url) || [],
        knowsAbout: ['Jamstack Development', 'React', 'Next.js', 'Astro', 'TypeScript', 'Sanity CMS', 'Headless CMS', 'Frontend Development', 'Web Performance', 'Tailwind CSS'],
      })}
    />

    <!-- Title -->
    <title>{title}</title>
  </head>
  <!-- Body -->
  <body class="bg-concrete text-ink antialiased">
    <Header />
    <main>
      <div class="container">
        <Breadcrumbs items={breadcrumbs} />
      </div>
      <slot />
    </main>
    <Footer />

    <script>
      import { initScrollReveal, initSectionReveal } from '@/lib/animations';
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
        initSectionReveal();
      });
    </script>
  </body>
</html>
