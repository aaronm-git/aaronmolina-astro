---
import SocialLinks from '@/components/molecules/SocialLinks.astro';
import navigation from '@/content/site/navigation.json';
import footer from '@/content/site/footer.json';
import settings from '@/content/site/settings.json';
import profile from '@/content/profile/profile.json';
import homepageContent from '@/content/site/homepage.json';

/**
 * Site-wide footer — renders the brand mark and summary, a sitemap column,
 * a "Hire Me" shortcuts column, and a bottom bar with the copyright line
 * and social links. All content is sourced from the site JSON collections
 * (navigation, footer, settings, profile, homepage), so this component
 * takes no props.
 */
const hireLinks = [
  { label: 'Overview', href: '/hire' },
  { label: 'React Developer', href: '/hire/react-developer' },
  { label: 'Next.js Developer', href: '/hire/nextjs-developer' },
  { label: 'Headless CMS', href: '/hire/headless-cms' },
];

const yearsOfExperience = new Date().getFullYear() - homepageContent.yearsOfExperienceStartYear;
const summary = profile.summary.replaceAll('{yearsOfExperience}', String(yearsOfExperience));
---

<footer class="border-signal bg-ink text-steel border-t-2">
  <div class="container py-12">
    <div class="border-seam grid grid-cols-1 gap-8 border-b pb-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="font-display text-concrete flex items-center gap-2 text-lg font-black tracking-tight uppercase">
          <span class="bg-signal text-ink flex h-7 w-7 items-center justify-center rounded-xs font-mono text-xs font-bold">AM</span>
          {navigation.brandText}
        </a>
        <p class="mt-3 max-w-[36ch] text-sm leading-relaxed">{summary}</p>
        <a href={`mailto:${settings.contact.email}`} class="text-signal mt-3 inline-block font-mono text-xs hover:underline">
          {settings.contact.email}
        </a>
      </div>

      <div>
        <h3 class="text-concrete mb-3 font-mono text-xs font-bold tracking-[0.16em] uppercase">Site</h3>
        <ul class="space-y-2">
          {
            navigation.navItems.map(item => (
              <li>
                <a href={item.href} class="text-steel hover:text-signal text-sm">
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/privacy" class="text-steel hover:text-signal text-sm">Privacy</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-concrete mb-3 font-mono text-xs font-bold tracking-[0.16em] uppercase">Hire Me</h3>
        <ul class="space-y-2">
          {
            hireLinks.map(link => (
              <li>
                <a href={link.href} class="text-steel hover:text-signal text-sm">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3 pt-6 font-mono text-xs tracking-[0.08em] uppercase">
      <span>&copy; {new Date().getFullYear()} {footer.copyrightOwnerName} &middot; {footer.copyrightSuffix}</span>
      {footer.showSocialLinks && settings.author.socialLinks?.length ? <SocialLinks links={settings.author.socialLinks} tone="dark" /> : null}
    </div>
  </div>
</footer>
