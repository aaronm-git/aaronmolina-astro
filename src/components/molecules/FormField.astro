---
type FieldType = 'text' | 'email' | 'url' | 'textarea' | 'select';

/** A single selectable choice rendered as an `<option>` when `type` is `'select'` */
interface Option {
  /** Value submitted for this option */
  value: string;
  /** Text displayed for this option */
  label: string;
}

/**
 * Molecule pairing a `<label>` with a form control, rendered as an input,
 * textarea, or select depending on `type`. Used to build the Contact form.
 */
interface Props {
  /** Text displayed in the `<label>` */
  label: string;
  /** Form control `name`/`id` attribute */
  name: string;
  /** Which form control to render */
  type?: FieldType;
  /** Marks the field as required for form submission */
  required?: boolean;
  /** Placeholder text for text/email/textarea; used as the blank default option's label when `type` is `'select'` */
  placeholder?: string;
  /** Initial value shown in the form control */
  value?: string;
  /** Number of visible rows; only applies when `type` is `'textarea'` */
  rows?: number;
  /** Choices to render; only applies when `type` is `'select'` */
  options?: Option[];
  /** Additional CSS classes */
  class?: string;
}

const { label, name, type = 'text', required = false, placeholder, value = '', rows = 5, options = [], class: className = '' } = Astro.props;

const fieldClasses =
  'w-full rounded-sm border-2 border-ink bg-paper px-3 py-2.5 text-sm text-ink placeholder:text-graphite focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-signal';
---

<div class={className}>
  <label for={name} class="text-ink mb-2 block font-mono text-xs font-bold tracking-[0.1em] uppercase">
    {label}
  </label>
  {
    type === 'textarea' ? (
      <textarea id={name} name={name} required={required} placeholder={placeholder} rows={rows} class={fieldClasses} set:text={value} />
    ) : type === 'select' ? (
      <select id={name} name={name} required={required} class={fieldClasses}>
        {placeholder && <option value="">{placeholder}</option>}
        {options.map(opt => (
          <option value={opt.value}>{opt.label}</option>
        ))}
      </select>
    ) : (
      <input id={name} name={name} type={type} required={required} placeholder={placeholder} value={value} class={fieldClasses} />
    )
  }
</div>
